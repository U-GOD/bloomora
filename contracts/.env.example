# Foundry deployment environment variables

# Private key of the deployer wallet (do NOT include the 0x prefix, just the hex string)
PRIVATE_KEY=

# Base network RPC URL (e.g., from Alchemy, Infura, or public RPC like https://mainnet.base.org)
BASE_RPC_URL=https://sepolia.base.org

# BaseScan API Key for contract verification
BASESCAN_API_KEY=

# (Optional) Ethereum RPC URL if interacting with mainnet
ETH_RPC_URL=https://eth.llamarpc.com
